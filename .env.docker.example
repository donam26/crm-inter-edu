# ============================================================
# Production .env template for the Docker deployment.
# On the server:  cp .env.docker.example .env  then fill the values.
# APP_KEY:  docker compose run --rm app php artisan key:generate --show
# ============================================================

APP_NAME="Inter Edu CRM"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://crm.interedu.ai.vn

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# --- Database (shared db-stack MySQL; host = compose service name "mysql") ---
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=crm_inter_edu
DB_USERNAME=crm
DB_PASSWORD=change_me

# --- Driver-backed-by-MySQL (no Redis dependency required) ---
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

QUEUE_CONNECTION=database
CACHE_STORE=database
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# --- Optional Redis (present in db-stack; switch the drivers above to use it) ---
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@crm.interedu.ai.vn"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# ---- docker-compose overrides (read by docker-compose.yml, not by Laravel) ----
APP_CONTAINER_NAME=crm-inter-edu
APP_BIND_HOST=127.0.0.1
APP_PORT=8000
RUN_MIGRATIONS=false
DB_NETWORK_NAME=db-stack_db_net
